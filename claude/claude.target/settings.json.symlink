{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "Bash(git add:*)",
      "Bash(git config:*)",
      "Bash(git checkout:*)",
      "Bash(command -v make && /usr/bin/make -n up 2>&1 || /usr/bin/env make -n up 2>&1)",
      "Bash(git status:*)",
      "Bash(python3:*)",
      "Bash(gh api:*)",
      "Bash(command diff:*)",
      "Bash(rm:*)",
      "Bash(gh pr:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(grep:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "mcp__claude_ai_Notion__notion-update-page",
      "Bash(git worktree *)",
      "Read(//home/nils/projects/outset-out-2048-monitoring/**)",
      "Bash(./scripts/worktree-init.sh)",
      "Bash(docker compose *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null && afplay ~/.claude/jobs_done.mp3 || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null && afplay ~/.claude/order_sir.m4a || true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "vercel@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "feedbackSurveyRate": 0,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking"
    ]
  },
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.89",
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipAutoPermissionPrompt": true
}
