#!/usr/bin/env bash
# Symlink every top-level dir in this repo into $HOME via GNU Stow.
# Each package's layout mirrors its destination under $HOME — e.g.
# zsh/.zshrc → ~/.zshrc, config/.config/starship.toml → ~/.config/starship.toml.
#
# Dirs that only contain *.zsh snippets (auto-sourced by zshrc, not symlinked)
# pass through harmlessly thanks to --ignore.
#
# Pass --clean once on first run after migrating from the old Ruby script: it
# removes any pre-existing symlinks under $HOME that point into a checkout of
# this repo, so stow can take over without conflicts.
set -euo pipefail

cd "$(dirname "$(readlink -f "$0")")"

if ! command -v stow >/dev/null; then
  echo "stow not installed — run \`brew bundle\` (or apt install stow) first." >&2
  exit 1
fi

if [[ "${1:-}" == "--clean" ]]; then
  echo "Removing pre-existing symlinks under \$HOME that point into the dotfiles repo."
  # Walk each package and check only the destinations it would stow, instead
  # of scanning all of $HOME. Skips *.zsh (snippets aren't stowed anyway).
  while IFS= read -r -d '' src; do
    rel=${src#./}
    rel=${rel#*/}                            # drop the package prefix
    dst=$HOME/$rel
    [[ -L "$dst" ]] || continue
    target=$(readlink "$dst" 2>/dev/null) || continue
    case "$target" in
      *.dotfiles/*|*.dotfiles) rm -f "$dst" ;;
    esac
  done < <(find ./*/ -type f ! -name '*.zsh' ! -path './bootstrap.d/*' -print0 2>/dev/null)
fi

# --no-folding stops stow from collapsing intermediate dirs (e.g. ~/.config)
# into directory symlinks, so adding a second package later doesn't surprise us.
# --ignore='\.zsh$' skips auto-sourced snippets so dirs like mise/ or aws/ that
# only contain those don't link the snippet itself into $HOME.
# Every non-hidden top-level dir is a package except bootstrap.d/ (post-setup
# scripts, run below). Adding a real package is still just
# `mkdir <pkg>/<dotfile path>` and re-running this script — no edit needed here.
packages=()
for dir in */; do
  [[ "$dir" == "bootstrap.d/" ]] && continue
  packages+=("$dir")
done
stow --target="$HOME" --no-folding --ignore='\.zsh$' --ignore='\.DS_Store$' --restow "${packages[@]}"

# Post-stow machine setup that can't be expressed as a symlink (system-binary
# workarounds, git hook installation, …). Each step is an idempotent, guarded,
# executable script under bootstrap.d/, run with the repo root as cwd. A step can
# be a bare script (bootstrap.d/foo.sh) or a script bundled with its data files
# in a subdir (bootstrap.d/foo/foo.sh); we walk one level of nesting and run
# every executable file, skipping non-executable companions (data, templates).
# Drop a new one in to add a step — no edit needed here.
shopt -s nullglob
for step in bootstrap.d/* bootstrap.d/*/*; do
  [[ -f "$step" && -x "$step" ]] || continue
  "$step"
done

echo "Dotfiles setup complete."
